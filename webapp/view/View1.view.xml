<mvc:View
    controllerName="demotest.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page id="page" title="{i18n>title}" showNavButton="false">
        <IconTabBar
            id="iconTabBar"
            expanded="{device>/isNoPhone}"
            class="sapUiResponsiveContentPadding"
            select="onTabSelect">
            <items>
                <IconTabFilter text="{i18n>tabOrders}" icon="sap-icon://table-chart" key="orders">
                    <content>
                        <Table
                            id="ordersTable"
                            inset="false"
                            mode="SingleSelectMaster"
                            growing="true"
                            growingThreshold="10"
                            selectionChange="onOrderSelect"
                            items="{view>/orders}">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="{i18n>tableTitle}" level="H2" />
                                    <ToolbarSpacer />
                                    <SearchField
                                        id="orderSearch"
                                        width="15rem"
                                        placeholder="{i18n>searchPlaceholder}"
                                        liveChange="onSearchOrders" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column width="8rem" hAlign="Begin">
                                    <Text text="{i18n>colOrderId}" />
                                </Column>
                                <Column minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
                                    <Text text="{i18n>colCustomer}" />
                                </Column>
                                <Column width="8rem" hAlign="Center" minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="{i18n>colStatus}" />
                                </Column>
                                <Column width="9rem" hAlign="End">
                                    <Text text="{i18n>colAmount}" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem vAlign="Middle">
                                    <cells>
                                        <Text text="{view>orderId}" />
                                        <Text text="{view>customer}" />
                                        <ObjectStatus text="{view>status}" state="{view>statusState}" />
                                        <ObjectNumber
                                            number="{view>amount}"
                                            unit="{view>currency}"
                                            emphasized="true" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </IconTabFilter>

                <IconTabFilter text="{i18n>tabControls}" icon="sap-icon://edit" key="controls">
                    <content>
                        <VBox class="sapUiSmallMargin">
                            <Title text="{i18n>controlsSectionTitle}" level="H4" class="sapUiSmallMarginBottom" />
                            <Label text="{i18n>labelCustomer}" labelFor="customerInput" />
                            <Input
                                id="customerInput"
                                value="{view>/form/customer}"
                                placeholder="{i18n>phCustomer}"
                                maxLength="60"
                                width="100%"
                                class="sapUiSmallMarginBottom" />

                            <Label text="{i18n>labelNotes}" labelFor="notesArea" />
                            <TextArea
                                id="notesArea"
                                value="{view>/form/notes}"
                                rows="3"
                                width="100%"
                                class="sapUiSmallMarginBottom" />

                            <Label text="{i18n>labelPriority}" labelFor="prioritySelect" />
                            <Select
                                id="prioritySelect"
                                width="100%"
                                selectedKey="{view>/form/priority}"
                                class="sapUiSmallMarginBottom">
                                <items>
                                    <core:Item key="H" text="{i18n>priorityHigh}" />
                                    <core:Item key="M" text="{i18n>priorityMedium}" />
                                    <core:Item key="L" text="{i18n>priorityLow}" />
                                </items>
                            </Select>

                            <Label text="{i18n>labelFlag}" />
                            <HBox class="sapUiSmallMarginBottom" alignItems="Center">
                                <Switch state="{view>/form/urgent}" customTextOn=" " customTextOff=" " />
                                <Text text="{i18n>urgentHint}" class="sapUiSmallMarginBegin" />
                            </HBox>

                            <Label text="{i18n>labelDate}" labelFor="dueDatePicker" />
                            <DatePicker
                                id="dueDatePicker"
                                value="{view>/form/dueDate}"
                                width="12rem"
                                class="sapUiSmallMarginBottom" />

                            <HBox class="sapUiMediumMarginTop" wrap="Wrap">
                                <Button
                                    text="{i18n>btnSubmit}"
                                    type="Emphasized"
                                    icon="sap-icon://save"
                                    press="onSubmit"
                                    class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />
                                <Button
                                    text="{i18n>btnReset}"
                                    icon="sap-icon://reset"
                                    press="onReset"
                                    class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />
                            </HBox>
                        </VBox>
                    </content>
                </IconTabFilter>

                <IconTabFilter text="{i18n>tabOverview}" icon="sap-icon://overview-chart" key="overview">
                    <content>
                        <Panel
                            headerText="{i18n>panelSummary}"
                            expandable="true"
                            expanded="true"
                            class="sapUiResponsiveMargin">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="{i18n>panelSummary}" level="H5" />
                                    <ToolbarSpacer />
                                    <Button icon="sap-icon://refresh" press="onRefreshFeed" tooltip="{i18n>btnRefresh}" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <content>
                                <Toolbar class="sapUiSmallMarginBottom" design="Transparent">
                                    <Text text="{i18n>toolbarHint}" />
                                </Toolbar>
                                <List
                                    id="feedList"
                                    items="{view>/feedItems}"
                                    mode="None">
                                    <StandardListItem
                                        title="{view>title}"
                                        description="{view>description}"
                                        icon="{view>icon}"
                                        type="Active"
                                        press="onFeedItemPress" />
                                </List>
                            </content>
                        </Panel>
                    </content>
                </IconTabFilter>
            </items>
        </IconTabBar>
    </Page>
</mvc:View>
